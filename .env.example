# Copy to .env and fill in real values from HachiAI.
# Values with spaces MUST be quoted (see HACHI_INBOX_PROMPT below).

# --- Saved automation (My Automations → Triggers → Doculytix V1) ---
HACHI_WEBHOOK_URL=https://dev-agent-backend.hachiai.com/api/webhooks/sources/doculytix/YOUR_TRIGGER_ID
HACHI_TRIGGER_SECRET=your-secret-from-hachiai
USE_HACHI_INBOX=0

# --- OR global inbox (Settings → General → External webhook inbox) ---
# USE_HACHI_INBOX=1
# HACHI_INBOX_URL=https://dev-agent-backend.hachiai.com/api/webhooks/inbox
# HACHI_INBOX_PROMPT="Process this invoice: extract vendor, line items, tax, and total."

# Default document URL in payload samples
DEFAULT_DOCUMENT_URL=https://docx.hachiai.com/storage/invoices/sample-invoice-2026.pdf

# Callback simulator port (docker compose)
PORT=8080
